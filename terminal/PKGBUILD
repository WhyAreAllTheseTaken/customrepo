#!/usr/bin/bash

pkgname="why-terminal"
pkgver=0.4.2
pkgrel=10
pkgdesc="My personal configuration for alacritty."
arch=(any)
depends=(
    "alacritty>=0.14" ttf-material-design-icons ttf-font-awesome
    )
source=("alacritty.toml")
install="install.sh"
sha256sums=("SKIP")

package() {
	mkdir -p $pkgdir/etc/skel/.config/alacritty/
	cp -r alacritty.toml $pkgdir/etc/skel/.config/alacritty/
}



