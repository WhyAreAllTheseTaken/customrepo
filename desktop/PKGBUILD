#!/usr/bin/bash

pkgname="why-desktop"
pkgver=0.22.1
pkgrel=11
pkgdesc="My custom desktop"
arch=(any)
depends=(dunst i3-wm i3blocks i3blocks-contrib picom flameshot feh lightdm
    xorg-server rofi pavucontrol hicolor-icon-theme pasystray network-manager-applet
    polkit brightnessctl procps betterlockscreen lxappearance materia-gtk-theme
    ttf-weather-icons xorg-xinput gtk3 bash coreutils lightdm-gtk-greeter sudo
    )
provides=("why-bg=0.11.9" "why-theme=0.13.4")
source=("i3config" "i3blocks.conf" "betterlockscreenrc" "dunstrc" "why-bg.sh" "why-theme.sh" "theme.conf" "picom.conf" "user-dirs.dirs" "user-dirs.locale"
    "lightdm-gtk-greeter.conf")
install="install.sh"
sha256sums=("SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP" "SKIP")

package() {
    cd "$pkgname-$pkgver"
	mkdir -p $pkgdir/etc/skel/.config/i3
	cp i3config $pkgdir/etc/skel/.config/i3
	mkdir -p $pkgdir/etc/skel/.config/i3blocks
	cp i3blocks.conf $pkgdir/etc/skel/.config/i3blocks
	mkdir -p $pkgdir/etc/skel/.config/betterlockscreen
	cp betterlockscreenrc $pkgdir/etc/skel/.config/betterlockscreen
	mkdir -p $pkgdir/etc/skel/.config/
	cp picom.conf $pkgdir/etc/skel/.config/
	cp user-dirs.dirs $pkgdir/etc/skel/.config/
	cp user-dirs.locale $pkgdir/etc/skel/.config/
	mkdir -p $pkgdir/etc/skel/.config/dunst/
	cp dunstrc $pkgdir/etc/skel/.config/dunst/dunstrc
	mkdir -p $pkgdir/etc/skel/.local/
	echo "ice" > $pkgdir/etc/skel/.local/why-theme 
	echo "/usr/share/backgrounds/why-ice.png" > $pkgdir/etc/skel/.local/why-bg-path 
	mkdir -p $pkgdir/etc/lightdm/
	cp lightdm-gtk-greeter.conf $pkgdir/etc/lightdm/lightdm-gtk-greeter.conf.why
	mkdir -p $pkgdir/usr/bin/
	cp why-bg.sh $pkgdir/usr/bin/why-bg
	chmod +x $pkgdir/usr/bin/why-bg
	cp why-theme.sh $pkgdir/usr/bin/why-theme
	chmod +x $pkgdir/usr/bin/why-theme
}

