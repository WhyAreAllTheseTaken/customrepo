#!/usr/bin/bash

pkgname="why-shell"
pkgver=0.11.1
pkgrel=3
pkgdesc="My personal configuration for a shell."
arch=(any)
depends=(
    zsh why-nnn tree htop fastfetch why-neovim
    )
source=(".zshenv" ".zshrc" ".zshrc.zni")
install="install.sh"
sha256sums=("SKIP" "SKIP" "SKIP")

package() {
	mkdir -p $pkgdir/etc/skel/
	cp .zshenv $pkgdir/etc/skel/.zshenv
	cp .zshrc $pkgdir/etc/skel/.zshrc
	cp .zshrc.zni $pkgdir/etc/skel/.zshrc.zni
}

